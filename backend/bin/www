#!/usr/bin/env node
// bin/www

const app = require('../app');
const http = require('http');
const connectDB = require('../config/db');

// ✅ FIX: Connect to MongoDB FIRST, then start listening
// This prevents 500 errors on /register when DB isn't ready
const startServer = async () => {
  try {
  await connectDB();              // ← DB connects FIRST
 // ← THEN routes + setInterval load (DB is ready)
const port = process.env.PORT   // ← Render's dynamic port

    const port = normalizePort(process.env.PORT || '5000');
    app.set('port', port);

    const server = http.createServer(app);
    server.listen(port);
    server.on('error', onError);
    server.on('listening', () => {
      const addr = server.address();
      const bind = typeof addr === 'string' ? 'pipe ' + addr : 'port ' + addr.port;
      console.log('🚀 Listening on ' + bind);
    });

  } catch (err) {
    console.error('❌ Failed to start server:', err);
    process.exit(1);
  }
};

startServer();

function normalizePort(val) {
  const port = parseInt(val, 10);
  if (isNaN(port)) return val;
  if (port >= 0) return port;
  return false;
}

function onError(error) {
  if (error.syscall !== 'listen') throw error;
  const bind = typeof port === 'string' ? 'Pipe ' + port : 'Port ' + port;
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}












